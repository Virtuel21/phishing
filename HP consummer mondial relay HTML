        var setCookie = (cName, cValue, expDays) => {
            let now = new Date();
            let expireTime = new Date(now.getTime() + (expDays * 24 * 60 * 60 * 1000));
            const expires = "expires=" + expireTime.toUTCString();
            document.cookie = cName + "=" + cValue + "; " + expires + "; path=/";
        }

        var getCookie = (cName) => {
            const name = cName + "=";
            const cDecoded = decodeURIComponent(document.cookie);
            const cArr = cDecoded.split("; ");
            let value;
            cArr.forEach(val => {
                if (val.indexOf(name) === 0) {
                    value = val.substring(name.length);
                }
            })

            return value;
        }

       

